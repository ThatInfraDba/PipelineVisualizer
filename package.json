{
  "name": "pipeline-visualizer",
  "displayName": "Pipeline Visualizer",
  "description": "Visualize Azure DevOps and GitHub Actions YAML pipelines with interactive diagrams",
  "version": "1.1.0",
  "publisher": "DannydeHaan",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ThatInfraDba/PipelineVisualizer.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "azure devops",
    "github actions",
    "pipeline",
    "yaml",
    "visualization",
    "ci/cd",
    "devops",
    "workflow",
    "diagram"
  ],
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pipelineVisualizer.visualize",
        "title": "Pipeline: Visualize",
        "category": "Pipeline",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceExtname == .yml || resourceExtname == .yaml",
          "command": "pipelineVisualizer.visualize",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "resourceExtname == .yml || resourceExtname == .yaml",
          "command": "pipelineVisualizer.visualize",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Pipeline Visualizer",
      "properties": {
        "pipelineVisualizer.diagramLayout": {
          "type": "string",
          "default": "automatic",
          "enum": ["automatic", "horizontal", "vertical"],
          "enumDescriptions": [
            "Automatically choose layout based on pipeline complexity (horizontal for 6 or fewer stages, vertical for more)",
            "Always use horizontal layout (left-to-right)",
            "Always use vertical layout (top-to-bottom)"
          ],
          "description": "Controls the orientation of the Mermaid diagram in pipeline visualizations"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "@types/js-yaml": "^4.0.9"
  }
}
